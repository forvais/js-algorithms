{
  "name": "@forvais/datastructures",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#datastructures/*": "./src/*"
  },
  "exports": {
    "./stack": {
      "types": "./dist/Stack.d.ts",
      "import": "./dist/Stack.js",
      "require": "./dist/Stack.cjs"
    },
    "./queue": {
      "types": "./dist/Queue.d.ts",
      "import": "./dist/Queue.js",
      "require": "./dist/Queue.cjs"
    },
    "./heap": {
      "types": "./dist/Heap.d.ts",
      "import": "./dist/Heap.js",
      "require": "./dist/Heap.cjs"
    },
    "./priority-queue": {
      "types": "./dist/PriorityQueue.d.ts",
      "import": "./dist/PriorityQueue.js",
      "require": "./dist/PriorityQueue.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup src --platform node --format cjs,esm --out-dir dist --clean --target esnext --cjsInterop --dts",
    "lint": "npm-run-all lint:*",
    "lint:eslint": "eslint src/ --no-error-on-unmatched-pattern",
    "lint:type-check": "tsc --noEmit",
    "prepare": "husky",
    "test:unit": "vitest run --dir __tests__/units --passWithNoTests"
  },
  "devDependencies": {
    "@forvais/eslint-config-base": "^2.0.0",
    "@forvais/eslint-config-typescript": "^1.0.0",
    "@types/node": "^24.10.10",
    "eslint": "^9.39.2",
    "fixpack": "^4.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.7.0",
    "pnpm": ">=10.28.2"
  },
  "packageManager": "pnpm@10.28.2",
  "lint-staged": {
    "*.{js,ts}": "eslint"
  }
}
