{
  "name": "@forvais/datastructures",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#datastructures/*": "./src/*"
  },
  "exports": {
    "./heap": {
      "import": "./dist/heap.mjs",
      "require": "./dist/heap.cjs"
    },
    "./priority-queue": {
      "import": "./dist/priority-queue.mjs",
      "require": "./dist/priority-queue.cjs"
    },
    "./queue": {
      "import": "./dist/queue.mjs",
      "require": "./dist/queue.cjs"
    },
    "./stack": {
      "import": "./dist/stack.mjs",
      "require": "./dist/stack.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "lint": "npm-run-all lint:*",
    "lint:eslint": "eslint src/ --no-error-on-unmatched-pattern",
    "lint:type-check": "tsc --noEmit",
    "prepare": "husky",
    "test:unit": "vitest run --dir __tests__/units --passWithNoTests"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@forvais/eslint-config-base": "^2.0.0",
    "@forvais/eslint-config-typescript": "^1.0.0",
    "@types/node": "^24.10.10",
    "eslint": "^9.39.2",
    "fixpack": "^4.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "publint": "^0.3.18",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.7.0",
    "pnpm": ">=10.28.2"
  },
  "packageManager": "pnpm@10.28.2",
  "lint-staged": {
    "*.{js,ts}": "eslint"
  }
}
